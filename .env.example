POSTGRES_DB=habilitation
POSTGRES_USER=habilitation
POSTGRES_PASSWORD=habilitation_dev

# JWT secret : generer avec
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_run_secrets_token_urlsafe_64

# Cle de chiffrement Fernet : generer avec
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FILE_ENCRYPTION_KEY=change_me_fernet_key

CORS_ORIGINS=http://localhost:5173
ENV=dev

# Secret partage avec n8n pour les endpoints internes /api/internal/...
# (etape 6 : relances). Generer avec :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Laisser vide pour desactiver les endpoints internes.
REMINDERS_SECRET=

# Secret partage avec le dashboard de pilotage du site web. Protege
# GET /api/pilotage/snapshot (taux de conformite global). Generer avec :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Laisser vide pour desactiver l'endpoint.
PILOTAGE_SECRET=

# URL du frontend, utilisee dans les magic_link des relances par email.
FRONTEND_BASE_URL=http://localhost:5173

# Resend (https://resend.com) : envoi d'emails de demande/relance.
# Si RESEND_API_KEY est vide, le bouton 'Envoyer la demande' fallback
# sur le magic_link copiable. MAIL_FROM doit etre une adresse autorisee
# par ton domaine Resend (ex: 'Habilitations 1MDP <habilitations@1mdp.fr>').
RESEND_API_KEY=
MAIL_FROM=Habilitations 1MDP <habilitations@example.com>
MAIL_REPLY_TO=

# DocuSign (etape 10e : signature de l'attestation sur l'honneur).
# Authentification JWT Grant. Si une des 4 premieres valeurs est vide,
# l'integration est desactivee (le bouton 'Envoyer pour signature'
# renvoie une erreur 503).
# - INTEGRATION_KEY / USER_ID / ACCOUNT_ID : depuis l'admin DocuSign.
# - PRIVATE_KEY : cle RSA. Sur une seule ligne, retours a la ligne
#   echappes en \n litteraux (ex: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END...).
# - ENV : 'production' (account.docusign.com) ou 'demo' (account-d.docusign.com).
# Au 1er appel, DocuSign peut exiger un consentement admin : l'erreur
# renvoyee contient l'URL a ouvrir une fois.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_TEMPLATE_ID=6da048a0-92a0-458e-a0e8-a2ae33090940
DOCUSIGN_ROLE_NAME=Salarie
DOCUSIGN_ENV=production
