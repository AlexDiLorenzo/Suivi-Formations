# Postgres : choisir un mot de passe fort, pas de defaut en prod
POSTGRES_DB=habilitation
POSTGRES_USER=habilitation
POSTGRES_PASSWORD=

# JWT secret : generer avec
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Cle de chiffrement Fernet (pour l'etape 3 : chiffrement des fichiers).
# Generer avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT : ne JAMAIS regenerer cette cle apres mise en prod sinon les
# documents deja chiffres deviennent illisibles.
FILE_ENCRYPTION_KEY=

# CORS : domaine du frontend (ajouter d'autres origines separees par virgule
# une fois le frontend en ligne)
CORS_ORIGINS=https://formations.alex-worksmart.com

# Secret partage avec n8n pour /api/internal/reminders/* (etape 6).
# Generer une seule fois et coller la meme valeur dans la config du
# noeud HTTP de n8n (header X-Internal-Secret). Generer :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REMINDERS_SECRET=

# URL du frontend en prod, utilisee pour construire les magic_link
# inseres dans les emails de relance.
FRONTEND_BASE_URL=https://formations.alex-worksmart.com

# Resend (https://resend.com) : envoi des emails de demande de document
# au depanneur. Generer une cle dans Resend > API Keys, autoriser
# l'adresse MAIL_FROM dans Resend > Domains. Si vide, le bouton
# 'Envoyer la demande' fallback sur le magic_link copiable.
RESEND_API_KEY=
MAIL_FROM=Habilitations 1MDP <habilitations@TON-DOMAINE>
MAIL_REPLY_TO=

# DocuSign (etape 10e : signature de l'attestation sur l'honneur).
# Authentification JWT Grant. Si une des 4 premieres valeurs est vide,
# l'integration est desactivee. Memes conventions que pour DepanTime.
# - PRIVATE_KEY : cle RSA sur une seule ligne, retours a la ligne en \n
#   litteraux (-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END...).
# - ENV : 'production' (account.docusign.com) ou 'demo' (account-d.docusign.com).
# Au 1er appel DocuSign peut exiger un consentement admin : l'erreur
# renvoyee contient l'URL de consentement a ouvrir une fois.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_TEMPLATE_ID=6da048a0-92a0-458e-a0e8-a2ae33090940
DOCUSIGN_ROLE_NAME=Salarie
DOCUSIGN_ENV=production
